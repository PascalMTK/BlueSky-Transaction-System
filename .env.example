# ── BLUESKY — Required environment variables ─────────────────────────────────
# Copy this file to .env for local development.
# On Railway, set these in the Railway dashboard (Variables tab).

# Django
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=yourdomain.railway.app,localhost
CSRF_TRUSTED_ORIGINS=https://yourdomain.railway.app

# Database — Railway provides this automatically when you add a MySQL plugin
DATABASE_URL=mysql://user:password@host:3306/dbname

# Local MySQL (used when DATABASE_URL is not set)
DB_NAME=bluesky_transactions
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Email (Gmail SMTP with App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=youraddress@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
EMAIL_FROM=BLUESKY Transactions <noreply@bluesky.com>

# Africa's Talking SMS (optional)
AT_USERNAME=sandbox
AT_API_KEY=
AT_SENDER_ID=BLUESKY
AT_SMS_ENABLED=False
